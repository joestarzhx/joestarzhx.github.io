name = "personal-blog-video-upload"
main = "src/index.js"
compatibility_date = "2026-06-01"

[[r2_buckets]]
binding = "VIDEO_BUCKET"
bucket_name = "personal-blog-videos"

[vars]
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-supabase-anon-key"
R2_PUBLIC_BASE_URL = "https://video.example.com"
ALLOWED_ORIGINS = "https://herobrine-z.github.io,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173"

# Store OWNER_USER_ID as a secret:
# npx wrangler secret put OWNER_USER_ID
